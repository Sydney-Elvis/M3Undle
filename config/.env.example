# Provider URL variables — used for %VAR% substitution in provider URLs.
# Copy this file to .env and fill in your actual values.
#
# Example: if a provider URL is http://%HOST%/live/%USER%/%PASS%/...
# define the variables below and M3Undle will substitute them at fetch time.
#
# These are NOT system/Docker env vars — they are only for URL substitution.
# Put system config (PUID, PGID, M3UNDLE_ENCRYPTION_KEY) in the root .env file.

# Example: single provider credentials
# USER=your_username_here
# PASS=your_password_here

# Example: multiple providers with distinct variable names
# MYPROVIDER_URL=https://provider.example.com/
# MYPROVIDER_USER=your_username_here
# MYPROVIDER_PASS=your_password_here
