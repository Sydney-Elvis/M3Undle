@using M3Undle.Web.Contracts.Providers
@using System.Text.Json
@inject HttpClient Http

<MudDialog Style="min-width:620px">
    <DialogContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-3">
            <MudChip T="string" Size="Size.Small" Color="@(Provider.IsXtreamProvider ? Color.Secondary : Color.Default)"
                     Icon="@(Provider.IsXtreamProvider ? Icons.Material.Filled.Tv : Icons.Material.Filled.Link)">
                @(Provider.IsXtreamProvider ? "Xtream Codes" : "URL / File")
            </MudChip>
        </MudStack>

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-3">@_error</MudAlert>
        }

        <MudForm @ref="_form">
            <MudStack Spacing="2">
                <MudTextField Label="Name" @bind-Value="_model.Name" Required="true" RequiredError="Name is required." />

                @if (Provider.IsXtreamProvider)
                {
                    <MudTextField Label="Server URL" @bind-Value="_model.XtreamBaseUrl"
                                  Required="true" RequiredError="Server URL is required."
                                  HelperText="e.g. http://yourserver.com:8080" />
                    <MudTextField Label="Username" @bind-Value="_model.XtreamUsername"
                                  Required="true" RequiredError="Username is required." />
                    <MudSwitch @bind-Value="_model.XtreamIncludeXmltv" Color="Color.Primary"
                               Label="Include XMLTV guide from same server" />
                }
                else
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudTextField Label="Playlist URL" @bind-Value="_model.PlaylistUrl"
                                      Required="true" RequiredError="A playlist URL is required."
                                      HelperText="http/https URL, or file:///path/to/file.m3u. Use %VAR_NAME% for credentials in .env."
                                      Style="flex:1" />
                        <MudTooltip Text="@_urlHelperText" Placement="Placement.Left">
                            <MudIconButton Icon="@Icons.Material.Filled.Help" Size="Size.Small" Color="Color.Info" />
                        </MudTooltip>
                    </MudStack>
                    <MudTextField Label="XMLTV URL (optional)" @bind-Value="_model.XmltvUrl" />
                    <MudTextField Label="User Agent (optional)" @bind-Value="_model.UserAgent" />
                    <MudTextField Label="Headers JSON (optional)" @bind-Value="_model.HeadersJson" Lines="2"
                                  HelperText='e.g. {"X-Custom-Header":"value"}' />
                }

                <MudNumericField T="int" Label="Timeout (seconds)" @bind-Value="_model.TimeoutSeconds" Min="1" Max="1800" />

                <MudSelect T="string" Label="Associated Profile" @bind-Value="_model.ProfileId"
                           ToStringFunc="@(id => string.IsNullOrEmpty(id) ? "(None)" : _localProfiles.FirstOrDefault(p => p.ProfileId == id)?.Name ?? id)">
                    <MudSelectItem T="string" Value="@string.Empty">(None)</MudSelectItem>
                    @foreach (var profile in AvailableProfiles)
                    {
                        <MudSelectItem T="string" Value="@profile.ProfileId">@profile.Name</MudSelectItem>
                    }
                </MudSelect>

                @if (!_showCreateProfile)
                {
                    <MudButton Variant="Variant.Text" Size="Size.Small" StartIcon="@Icons.Material.Filled.Add"
                               OnClick="ShowCreateProfile" Style="align-self:flex-start">New Profile</MudButton>
                }
                else
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudTextField Label="New Profile Name" @bind-Value="_newProfileName" Style="flex:1"
                                      Disabled="_isCreatingProfile" />
                        <MudIconButton Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Success"
                                       OnClick="CreateProfileAsync" Disabled="_isCreatingProfile" />
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                       OnClick="CancelCreateProfile" Disabled="_isCreatingProfile" />
                    </MudStack>
                }

                <MudDivider Class="my-1" />
                <MudText Typo="Typo.caption" Color="Color.Secondary">Content Types</MudText>
                <MudSwitch @bind-Value="_model.IncludeVod" Color="Color.Primary" Label="Include VOD / Movies" />
                <MudSwitch @bind-Value="_model.IncludeSeries" Color="Color.Primary" Label="Include Series" />
                <MudSwitch @bind-Value="_model.Enabled" Color="Color.Success" Label="Enabled" />
            </MudStack>
        </MudForm>

        @if (Provider.IsXtreamProvider)
        {
            <MudDivider Class="my-4" />
            <MudText Typo="Typo.subtitle2" Class="mb-2">Change Password</MudText>

            @if (!_encryptionAvailable)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-2">
                    <MudText Typo="Typo.body2">
                        <strong>M3UNDLE_ENCRYPTION_KEY is not set.</strong> Password changes require encryption to be configured.
                    </MudText>
                </MudAlert>
            }
            else
            {
                @if (!string.IsNullOrWhiteSpace(_passwordError))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-2">@_passwordError</MudAlert>
                }
                @if (!string.IsNullOrWhiteSpace(_passwordSuccess))
                {
                    <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mb-2">@_passwordSuccess</MudAlert>
                }
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudTextField @bind-Value="_newPassword" Label="New Password" InputType="InputType.Password"
                                  Style="flex:1" Disabled="_isChangingPassword" />
                    <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                               Disabled="@(_isChangingPassword || string.IsNullOrWhiteSpace(_newPassword))"
                               OnClick="ChangePasswordAsync">
                        @(_isChangingPassword ? "Updating..." : "Update")
                    </MudButton>
                </MudStack>
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel" Disabled="_isSaving">Cancel</MudButton>
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="_isSaving" OnClick="SaveAsync">
            @(_isSaving ? "Saving..." : "Save Changes")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public ProviderDto Provider { get; set; } = default!;
    [Parameter] public List<ProfileListItemDto> Profiles { get; set; } = [];
    [Parameter] public List<ProviderDto> Providers { get; set; } = [];
    [Parameter] public EventCallback OnSaved { get; set; }

    private MudForm? _form;
    private bool _isSaving;
    private bool _isChangingPassword;
    private string? _error;
    private string? _passwordError;
    private string? _passwordSuccess;
    private bool _encryptionAvailable;

    private List<ProfileListItemDto> _localProfiles = [];
    private bool _showCreateProfile;
    private string _newProfileName = string.Empty;
    private bool _isCreatingProfile;
    private string _newPassword = string.Empty;

    private EditModel _model = new();

    private const string _urlHelperText =
        "Enter an http/https URL, or file:///path/to/file.m3u for a server-side file.\n\n" +
        "To keep credentials out of the database, place them in .env in M3UNDLE_CONFIG_DIR " +
        "and reference with %VAR_NAME% syntax.\n\nExample: http://server:8080/get.php?password=%MY_PASS%";

    protected override async Task OnInitializedAsync()
    {
        _localProfiles = [.. Profiles];

        _model = Provider.IsXtreamProvider
            ? new EditModel
            {
                Name = Provider.Name,
                XtreamBaseUrl = Provider.XtreamBaseUrl ?? string.Empty,
                XtreamUsername = Provider.XtreamUsername ?? string.Empty,
                XtreamIncludeXmltv = Provider.XtreamIncludeXmltv,
                Enabled = Provider.Enabled,
                TimeoutSeconds = Provider.TimeoutSeconds,
                IncludeVod = Provider.IncludeVod,
                IncludeSeries = Provider.IncludeSeries,
                ProfileId = Provider.AssociatedProfileIds.FirstOrDefault() ?? string.Empty,
            }
            : new EditModel
            {
                Name = Provider.Name,
                PlaylistUrl = Provider.PlaylistUrl,
                XmltvUrl = Provider.XmltvUrl,
                UserAgent = Provider.UserAgent,
                HeadersJson = Provider.HeadersJson,
                Enabled = Provider.Enabled,
                TimeoutSeconds = Provider.TimeoutSeconds,
                IncludeVod = Provider.IncludeVod,
                IncludeSeries = Provider.IncludeSeries,
                ProfileId = Provider.AssociatedProfileIds.FirstOrDefault() ?? string.Empty,
            };

        if (Provider.IsXtreamProvider)
        {
            try
            {
                var r = await Http.GetAsync("/api/v1/providers/encryption-status");
                var body = await r.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                _encryptionAvailable = body.GetProperty("available").GetBoolean();
            }
            catch { _encryptionAvailable = false; }
        }
    }

    private IEnumerable<ProfileListItemDto> AvailableProfiles => _localProfiles.Where(p =>
        p.ProfileId == _model.ProfileId ||
        !Providers.Any(prov =>
            prov.ProviderId != Provider.ProviderId &&
            prov.AssociatedProfileIds.Contains(p.ProfileId)));

    private void Cancel() => MudDialog.Cancel();

    private void ShowCreateProfile()
    {
        _newProfileName = string.Empty;
        _showCreateProfile = true;
    }

    private void CancelCreateProfile()
    {
        _showCreateProfile = false;
        _newProfileName = string.Empty;
    }

    private async Task CreateProfileAsync()
    {
        if (string.IsNullOrWhiteSpace(_newProfileName)) return;
        _isCreatingProfile = true;
        _error = null;
        try
        {
            var response = await Http.PostAsJsonAsync("/api/v1/profiles",
                new CreateProfileRequest { Name = _newProfileName.Trim() });
            if (!response.IsSuccessStatusCode) { _error = await ReadErrorAsync(response); return; }
            var created = await response.Content.ReadFromJsonAsync<ProfileListItemDto>();
            if (created is not null) { _localProfiles.Add(created); _model.ProfileId = created.ProfileId; }
            _showCreateProfile = false;
            _newProfileName = string.Empty;
        }
        catch (Exception ex) { _error = $"Failed to create profile: {ex.Message}"; }
        finally { _isCreatingProfile = false; }
    }

    private async Task SaveAsync()
    {
        _error = null;
        _isSaving = true;
        try
        {
            if (_form is not null) { await _form.Validate(); if (!_form.IsValid) return; }

            var profileIds = string.IsNullOrWhiteSpace(_model.ProfileId) ? null : new List<string> { _model.ProfileId };

            UpdateProviderRequest request;
            if (Provider.IsXtreamProvider)
            {
                request = new UpdateProviderRequest
                {
                    Name = _model.Name.Trim(),
                    XtreamBaseUrl = _model.XtreamBaseUrl,
                    XtreamUsername = _model.XtreamUsername,
                    XtreamIncludeXmltv = _model.XtreamIncludeXmltv,
                    Enabled = _model.Enabled,
                    TimeoutSeconds = _model.TimeoutSeconds,
                    IncludeVod = _model.IncludeVod,
                    IncludeSeries = _model.IncludeSeries,
                    AssociateToProfileIds = profileIds,
                };
            }
            else
            {
                request = new UpdateProviderRequest
                {
                    Name = _model.Name.Trim(),
                    PlaylistUrl = _model.PlaylistUrl,
                    XmltvUrl = NullIfEmpty(_model.XmltvUrl),
                    UserAgent = NullIfEmpty(_model.UserAgent),
                    HeadersJson = NullIfEmpty(_model.HeadersJson),
                    Enabled = _model.Enabled,
                    TimeoutSeconds = _model.TimeoutSeconds,
                    IncludeVod = _model.IncludeVod,
                    IncludeSeries = _model.IncludeSeries,
                    AssociateToProfileIds = profileIds,
                };
            }

            var response = await Http.PutAsJsonAsync($"/api/v1/providers/{Provider.ProviderId}", request);
            if (!response.IsSuccessStatusCode) { _error = await ReadErrorAsync(response); return; }

            await OnSaved.InvokeAsync();
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex) { _error = $"Failed to save provider: {ex.Message}"; }
        finally { _isSaving = false; }
    }

    private async Task ChangePasswordAsync()
    {
        _passwordError = null;
        _passwordSuccess = null;
        _isChangingPassword = true;
        try
        {
            var response = await Http.PatchAsJsonAsync(
                $"/api/v1/providers/{Provider.ProviderId}/xtream-password",
                new UpdateXtreamPasswordRequest { Password = _newPassword });
            if (!response.IsSuccessStatusCode) { _passwordError = await ReadErrorAsync(response); return; }
            _passwordSuccess = "Password updated successfully.";
            _newPassword = string.Empty;
        }
        catch (Exception ex) { _passwordError = $"Failed to update password: {ex.Message}"; }
        finally { _isChangingPassword = false; }
    }

    private static string? NullIfEmpty(string? v) => string.IsNullOrWhiteSpace(v) ? null : v.Trim();

    private static async Task<string> ReadErrorAsync(HttpResponseMessage response)
    {
        var body = await response.Content.ReadAsStringAsync();
        if (string.IsNullOrWhiteSpace(body))
            return $"Request failed: {(int)response.StatusCode} {response.ReasonPhrase}";
        try
        {
            using var doc = JsonDocument.Parse(body);
            if (doc.RootElement.ValueKind == JsonValueKind.Object)
            {
                if (doc.RootElement.TryGetProperty("errors", out var errors) && errors.ValueKind == JsonValueKind.Object)
                {
                    var msgs = new List<string>();
                    foreach (var err in errors.EnumerateObject())
                        foreach (var msg in err.Value.EnumerateArray())
                        { var t = msg.GetString(); if (!string.IsNullOrWhiteSpace(t)) msgs.Add(t); }
                    if (msgs.Count > 0) return string.Join("; ", msgs);
                }
                if (doc.RootElement.TryGetProperty("title", out var title))
                {
                    var detail = doc.RootElement.TryGetProperty("detail", out var dp) ? dp.GetString() : null;
                    return string.IsNullOrWhiteSpace(detail) ? title.GetString() ?? "Request failed" : $"{title.GetString()}: {detail}";
                }
            }
        }
        catch (JsonException) { }
        return body;
    }

    private sealed class EditModel
    {
        public string Name { get; set; } = string.Empty;
        // URL/File fields
        public string? PlaylistUrl { get; set; }
        public string? XmltvUrl { get; set; }
        public string? UserAgent { get; set; }
        public string? HeadersJson { get; set; }
        // Xtream fields
        public string XtreamBaseUrl { get; set; } = string.Empty;
        public string XtreamUsername { get; set; } = string.Empty;
        public bool XtreamIncludeXmltv { get; set; }
        // Common
        public bool Enabled { get; set; } = true;
        public int TimeoutSeconds { get; set; } = 120;
        public bool IncludeVod { get; set; }
        public bool IncludeSeries { get; set; }
        public string ProfileId { get; set; } = string.Empty;
    }
}
