# ─────────────────────────────────────────────────────────────────────────────
# M3Undle — single secrets file
# Copy this to .env and fill in your values. This file is the only config
# you need for both Docker and local dev.
# ─────────────────────────────────────────────────────────────────────────────

# Docker user/group IDs — match your host user so files are owned correctly.
# Find yours with: id
PUID=1000
PGID=1000

# AES-256-GCM key for encrypting Xtream Codes passwords at rest.
# Required if you use Xtream Codes providers.
# Generate: openssl rand -base64 32
M3UNDLE_ENCRYPTION_KEY=your-base64-32-byte-key-here

# ─────────────────────────────────────────────────────────────────────────────
# Provider URL variables (optional)
# Add credentials for providers that use %VAR% placeholders in their URLs.
# Example URL: http://%MY_HOST%/live/%MY_USER%/%MY_PASS%/...
# ─────────────────────────────────────────────────────────────────────────────

# MY_HOST=provider.example.com
# MY_USER=your_username
# MY_PASS=your_password
