{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"type": "process",
			"command": "dotnet",
			"args": [
				"build",
				"${workspaceFolder}/src/M3Undle.Cli/M3Undle.Cli.csproj",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"problemMatcher": "$msCompile",
			"group": "build"
		},
		{
			"label": "build-web",
			"type": "process",
			"command": "dotnet",
			"args": [
				"build",
				"${workspaceFolder}/src/M3Undle.Web/M3Undle.Web.csproj",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"problemMatcher": "$msCompile"
		},
		{
			"label": "watch-web",
			"type": "process",
			"command": "dotnet",
			"args": [
				"watch",
				"--project",
				"${workspaceFolder}/src/M3Undle.Web/M3Undle.Web.csproj",
				"--",
				"--urls",
				"http://localhost:5283"
			],
			"options": {
				"env": {
					"ASPNETCORE_ENVIRONMENT": "Development",
					"M3UNDLE_CONFIG_DIR": "${workspaceFolder}/.config"
				}
			},
			"isBackground": true,
			"problemMatcher": {
				"owner": "mscompile",
				"pattern": "$msCompile",
				"background": {
					"activeOnStart": true,
					"beginsPattern": "dotnet watch",
					"endsPattern": "Now listening on:"
				}
			}
		},
		{
			"type": "docker-build",
			"label": "docker-build: debug",
			"dockerBuild": {
				"tag": "m3undle:web-debug",
				"target": "final",
				"dockerfile": "${workspaceFolder}/Dockerfile",
				"context": "${workspaceFolder}"
			},
			"netCore": {
				"appProject": "${workspaceFolder}/src/M3Undle.Web/M3Undle.Web.csproj"
			}
		},
		{
			"type": "docker-run",
			"label": "docker-run: m3undle-debug",
			"dependsOn": [
				"docker-stop: m3undle-debug",
				"docker-build: debug",
				"docker-ensure: dev dirs"
			],
			"dependsOrder": "sequence",
			"dockerRun": {
				"containerName": "m3undle-dev",
				"image": "m3undle:web-debug",
				"remove": false,
				"env": {
					"ASPNETCORE_ENVIRONMENT": "Development",
					"ASPNETCORE_URLS": "http://+:8080",
					"M3UNDLE_CONFIG_DIR": "/config"
				},
				"volumes": [
					{
						"localPath": "${workspaceFolder}/.config",
						"containerPath": "/config",
						"permissions": "ro"
					},
					{
						"localPath": "${workspaceFolder}/m3u_data",
						"containerPath": "/m3u_data",
						"permissions": "ro"
					},
					{
						"localPath": "${workspaceFolder}/data",
						"containerPath": "/data",
						"permissions": "rw"
					}
				],
				"customOptions": "--user root",
				"ports": [
					{
						"hostPort": 8080,
						"containerPort": 8080
					}
				]
			},
			"netCore": {
				"appProject": "${workspaceFolder}/src/M3Undle.Web/M3Undle.Web.csproj",
				"enableDebugging": true
			}
		},
		{
			"type": "docker-run",
			"label": "docker-run: force-debug",
			"dependsOn": [
				"docker-reset: data folder",
				"docker-ensure: dev dirs",
				"docker-build: force-debug"
			],
			"dependsOrder": "sequence",
			"dockerRun": {
				"containerName": "m3undle-dev",
				"image": "m3undle:web-debug",
				"remove": false,
				"env": {
					"ASPNETCORE_ENVIRONMENT": "Development",
					"ASPNETCORE_URLS": "http://+:8080",
					"M3UNDLE_CONFIG_DIR": "/config"
				},
				"volumes": [
					{
						"localPath": "${workspaceFolder}/.config",
						"containerPath": "/config",
						"permissions": "ro"
					},
					{
						"localPath": "${workspaceFolder}/m3u_data",
						"containerPath": "/m3u_data",
						"permissions": "ro"
					},
					{
						"localPath": "${workspaceFolder}/data",
						"containerPath": "/data",
						"permissions": "rw"
					}
				],
				"customOptions": "--user root",
				"ports": [
					{
						"hostPort": 8080,
						"containerPort": 8080
					}
				]
			},
			"netCore": {
				"appProject": "${workspaceFolder}/src/M3Undle.Web/M3Undle.Web.csproj",
				"enableDebugging": true
			}
		},
		{
			"type": "docker-run",
			"label": "docker-run: release",
			"dependsOn": [
				"docker-build: debug"
			],
			"dockerRun": {
				"customOptions": "--user root --rm",
				"ports": [
					{
						"hostPort": 8080,
						"containerPort": 8080
					}
				]
			}
		},
		{
			"label": "docker-stop: m3undle-debug",
			"type": "process",
			"command": "sh",
			"args": [
				"-c",
				"docker container inspect m3undle-dev >/dev/null 2>&1 && docker rm -f m3undle-dev >/dev/null 2>&1 || true"
			],
			"windows": {
				"command": "powershell",
				"args": [
					"-NoProfile",
					"-ExecutionPolicy",
					"Bypass",
					"-Command",
					"$null = docker container inspect m3undle-dev 2>$null; if ($LASTEXITCODE -eq 0) { docker rm -f m3undle-dev | Out-Null }; exit 0"
				]
			},
			"problemMatcher": []
		},
		{
			"label": "docker-clean: debug image",
			"type": "process",
			"command": "docker",
			"args": [
				"image",
				"rm",
				"-f",
				"m3undle:web-debug"
			],
			"problemMatcher": []
		},
		{
			"label": "docker-ensure: dev dirs",
			"type": "process",
			"command": "sh",
			"args": [
				"-c",
				"mkdir -p \"${workspaceFolder}/.config\" \"${workspaceFolder}/m3u_data\" \"${workspaceFolder}/data\""
			],
			"windows": {
				"command": "powershell",
				"args": [
					"-NoProfile",
					"-ExecutionPolicy",
					"Bypass",
					"-Command",
					"@('.config','m3u_data','data') | ForEach-Object { $d = Join-Path '${workspaceFolder}' $_; if (-not (Test-Path $d)) { New-Item -ItemType Directory -Force -Path $d | Out-Null }; Write-Host \"Ensured: $d\" }"
				]
			},
			"problemMatcher": []
		},
		{
			"label": "docker-reset: data folder",
			"type": "process",
			"command": "sh",
			"args": [
				"-c",
				"mkdir -p \"${workspaceFolder}/data\"; find \"${workspaceFolder}/data\" -mindepth 1 -maxdepth 1 -exec rm -rf {} + 2>/dev/null || true; echo \"Reset data directory: ${workspaceFolder}/data\""
			],
			"windows": {
				"command": "powershell",
				"args": [
					"-NoProfile",
					"-ExecutionPolicy",
					"Bypass",
					"-Command",
					"$dataDir = Join-Path '${workspaceFolder}' 'data'; if (-not (Test-Path $dataDir)) { New-Item -ItemType Directory -Force -Path $dataDir | Out-Null }; Get-ChildItem -LiteralPath $dataDir -Force -ErrorAction SilentlyContinue | Remove-Item -Recurse -Force -ErrorAction SilentlyContinue; Write-Host \"Reset data directory: $dataDir\"; exit 0"
				]
			},
			"problemMatcher": []
		},
		{
			"type": "docker-build",
			"label": "docker-build: force-debug",
			"dependsOn": [
				"docker-stop: m3undle-debug",
				"docker-reset: data folder"
			],
			"dependsOrder": "sequence",
			"dockerBuild": {
				"tag": "m3undle:web-debug",
				"target": "final",
				"dockerfile": "${workspaceFolder}/Dockerfile",
				"context": "${workspaceFolder}",
				"customOptions": "--no-cache"
			},
			"netCore": {
				"appProject": "${workspaceFolder}/src/M3Undle.Web/M3Undle.Web.csproj"
			}
		}
	]
}
